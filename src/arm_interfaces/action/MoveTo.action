# MoveTo: 사전 정의된 자세로 이동

# ---- Goal ----
string target_name                     # 움직여야 할 자세
uint8  attempt                         # 시도 횟수
---
# ---- Result ----
bool success                           # 성공 여부
FailureReport failure                  # 실패 상세. success=true failure.code == SUCCESS
---
# ---- Feedback ----
string stage                           # 단계별 동작
float32 progress                       # 진행률
