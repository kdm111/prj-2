# Place: 물건을 놓는 동작

# ---- Goal ----
string target_id                       # 놓아야 할 곳의 아이디
uint8  attempt                         # 시도 횟수
---
# ---- Result ----
bool success                           # 성공 여부
FailureReport failure                  # 실패 상세. success=true failure.code == SUCCESS
---
# ---- Feedback ----
string stage                           # 단계별 동작
float32 progress                       # 진행률
